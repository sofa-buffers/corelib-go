{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "timezone": "Europe/Berlin",
  "schedule": ["before 6am on monday"],
  "labels": ["dependencies"],
  "postUpdateOptions": ["gomodTidy"],
  "packageRules": [
    {
      "description": "Group all GitHub Actions bumps into one PR.",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    },
    {
      "description": "Go module updates (go directive in go.mod; the library is stdlib-only today).",
      "matchManagers": ["gomod"],
      "groupName": "go modules"
    },
    {
      "description": "Devcontainer base image (.devcontainer/Dockerfile -> ubuntu).",
      "matchManagers": ["dockerfile"],
      "groupName": "devcontainer image"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Track the pinned Go toolchain (ARG GO_VERSION) in the devcontainer Dockerfile.",
      "managerFilePatterns": ["/(^|/)\\.devcontainer/Dockerfile$/"],
      "matchStrings": ["ARG GO_VERSION=(?<currentValue>\\S+)"],
      "depNameTemplate": "go",
      "datasourceTemplate": "golang-version",
      "versioningTemplate": "semver"
    }
  ]
}
